# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Python bytecode / cache
__pycache__/
*.py[cod]

# Local environment
.env
.env.*

# Temporary files and previews (root level)
preview_*.html
temp_*
test_*.html
upload_*.py
temp*.png
temp*.pdf
temp*.html

# NODE
node_modules/

# Backup files (generated by pipeline)
.backups/
*.backup.venv/

# Large batch API intermediate files
.batch_runs/

# Generated pipeline data (checkpoints, item XMLs, backups — NEVER commit these)
app/data/question-generation/*/checkpoints/
app/data/question-generation/*/items/
app/data/question-generation/.rerun_backups/

# Ad-hoc operational input files (used at runtime, not code)
*_atoms.json
rerun_*.json

# Ad-hoc analysis output
research/pipeline-analysis/
