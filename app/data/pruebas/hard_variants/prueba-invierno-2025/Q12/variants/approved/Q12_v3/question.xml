    <qti-choice-interaction response-identifier="RESPONSE" shuffle="false" max-choices="1">
      
      <qti-simple-choice identifier="ChoiceA">A) Ana dice que el 15% de 80 000 pesos es 15 000 pesos.</qti-simple-choice>
      <qti-simple-choice identifier="ChoiceB">B) Bruno dice que el 15% de 80 000 pesos es 12 000 pesos.</qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceC">C) Carla dice que el 15% de 80 000 pesos es 92 000 pesos.</qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceD">D) Diego dice que el 15% de 80 000 pesos es 120 000 pesos.</qti-simple-choice>
    </qti-choice-interaction>
  </qti-item-body>
