<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0" xmlns:m="http://www.w3.org/1998/Math/MathML" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" identifier="Q20_v9" title="Q20_v9" time-dependent="false" adaptive="false" xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd">
  <qti-response-declaration identifier="RESPONSE" cardinality="single" base-type="identifier">
    <qti-correct-response>
      <qti-value>ChoiceB</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="FEEDBACK" cardinality="single" base-type="identifier"/>
  <qti-outcome-declaration identifier="SOLUTION" cardinality="single" base-type="identifier"/>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float"><qti-default-value><qti-value>0</qti-value></qti-default-value></qti-outcome-declaration>
  <qti-item-body>
    <p>Entre las siguientes expresiones escritas como suma de potencias de 10, ¿cuál representa un número mayor que 50 000 y menor que 60 000?</p>
    <qti-choice-interaction response-identifier="RESPONSE" shuffle="false" max-choices="1">
      <qti-prompt>¿Cuál de las siguientes expresiones representa correctamente la situación descrita?</qti-prompt>
      <qti-simple-choice identifier="ChoiceA">
        <m:math>
          <m:mrow>
            <m:mn>4</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>8</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>3</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>5</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>0</m:mn></m:msup>
          </m:mrow>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceA" outcome-identifier="FEEDBACK">Incorrecto. Esta expresión representa <m:math><m:mrow><m:mn>4</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup><m:mo>+</m:mo><m:mn>8</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>3</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup><m:mo>+</m:mo><m:mn>5</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>0</m:mn></m:msup><m:mo>=</m:mo><m:mn>40&#160;000</m:mn><m:mo>+</m:mo><m:mn>800</m:mn><m:mo>+</m:mo><m:mn>30</m:mn><m:mo>+</m:mo><m:mn>5</m:mn><m:mo>=</m:mo><m:mn>40&#160;835</m:mn></m:mrow></m:math>. Como <m:math><m:mrow><m:mn>40&#160;835</m:mn><m:mo>&lt;</m:mo><m:mn>50&#160;000</m:mn></m:mrow></m:math>, no es un número mayor que 50 000 y menor que 60 000.</qti-feedback-inline>
      </qti-simple-choice>
      <qti-simple-choice identifier="ChoiceB">
        <m:math>
          <m:mrow>
            <m:mn>5</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>7</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>9</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>1</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>0</m:mn></m:msup>
          </m:mrow>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceB" outcome-identifier="FEEDBACK">¡Correcto! Esta expresión representa <m:math><m:mrow><m:mn>5</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup><m:mo>+</m:mo><m:mn>7</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>9</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup><m:mo>+</m:mo><m:mn>1</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>0</m:mn></m:msup><m:mo>=</m:mo><m:mn>50&#160;000</m:mn><m:mo>+</m:mo><m:mn>700</m:mn><m:mo>+</m:mo><m:mn>90</m:mn><m:mo>+</m:mo><m:mn>1</m:mn><m:mo>=</m:mo><m:mn>50&#160;791</m:mn></m:mrow></m:math>. Como <m:math><m:mrow><m:mn>50&#160;000</m:mn><m:mo>&lt;</m:mo><m:mn>50&#160;791</m:mn><m:mo>&lt;</m:mo><m:mn>60&#160;000</m:mn></m:mrow></m:math>, sí cumple la condición pedida.</qti-feedback-inline>
      </qti-simple-choice>
      <qti-simple-choice identifier="ChoiceC">
        <m:math>
          <m:mrow>
            <m:mn>6</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>1</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>3</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>2</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>4</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup>
          </m:mrow>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceC" outcome-identifier="FEEDBACK">Incorrecto. Esta expresión representa <m:math><m:mrow><m:mn>6</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup><m:mo>+</m:mo><m:mn>1</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>3</m:mn></m:msup><m:mo>+</m:mo><m:mn>2</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>4</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup><m:mo>=</m:mo><m:mn>60&#160;000</m:mn><m:mo>+</m:mo><m:mn>1000</m:mn><m:mo>+</m:mo><m:mn>200</m:mn><m:mo>+</m:mo><m:mn>40</m:mn><m:mo>=</m:mo><m:mn>61&#160;240</m:mn></m:mrow></m:math>. Como <m:math><m:mrow><m:mn>61&#160;240</m:mn><m:mo>&gt;</m:mo><m:mn>60&#160;000</m:mn></m:mrow></m:math>, no es menor que 60 000.</qti-feedback-inline>
      </qti-simple-choice>
      <qti-simple-choice identifier="ChoiceD">
        <m:math>
          <m:mrow>
            <m:mn>1</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>5</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>2</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>3</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>3</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup>
            <m:mo>+</m:mo>
            <m:mn>4</m:mn><m:mo>⋅</m:mo>
            <m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup>
          </m:mrow>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceD" outcome-identifier="FEEDBACK">Incorrecto. Esta expresión representa <m:math><m:mrow><m:mn>1</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>5</m:mn></m:msup><m:mo>+</m:mo><m:mn>2</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>3</m:mn></m:msup><m:mo>+</m:mo><m:mn>3</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>4</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup><m:mo>=</m:mo><m:mn>100&#160;000</m:mn><m:mo>+</m:mo><m:mn>2000</m:mn><m:mo>+</m:mo><m:mn>300</m:mn><m:mo>+</m:mo><m:mn>40</m:mn><m:mo>=</m:mo><m:mn>102&#160;340</m:mn></m:mrow></m:math>. Como <m:math><m:mrow><m:mn>102&#160;340</m:mn><m:mo>&gt;</m:mo><m:mn>60&#160;000</m:mn></m:mrow></m:math>, no cumple la condición pedida.</qti-feedback-inline>
      </qti-simple-choice>
    </qti-choice-interaction>
    <qti-feedback-block identifier="FB_NoResponse" outcome-identifier="FEEDBACK" show-hide="show">
      <qti-content-body>
        <p>Debes seleccionar una alternativa para recibir retroalimentación específica.</p>
      </qti-content-body>
    </qti-feedback-block>
    <qti-feedback-block identifier="show" outcome-identifier="SOLUTION" show-hide="show">
      <qti-content-body>
        <p><strong>Resolución paso a paso</strong></p>
        <ol>
          <li>
            <p><strong>Paso 1: Identificar la condición del problema</strong></p>
            <p>Se busca una expresión que represente un número <strong>mayor que 50 000</strong> y <strong>menor que 60 000</strong>.</p>
            <p>Eso significa que el número debe cumplir simultáneamente:</p>
            <m:math>
              <m:mrow>
                <m:mn>50&#160;000</m:mn><m:mo>&lt;</m:mo><m:mi>N</m:mi><m:mo>&lt;</m:mo><m:mn>60&#160;000</m:mn>
              </m:mrow>
            </m:math>
          </li>
          <li>
            <p><strong>Paso 2: Calcular el valor de cada opción</strong></p>
            <p><em>Opción A:</em></p>
            <m:math>
              <m:mrow>
                <m:mn>4</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>8</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>3</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>5</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>0</m:mn></m:msup>
                <m:mo>=</m:mo><m:mn>40&#160;000</m:mn><m:mo>+</m:mo><m:mn>800</m:mn><m:mo>+</m:mo><m:mn>30</m:mn><m:mo>+</m:mo><m:mn>5</m:mn>
                <m:mo>=</m:mo><m:mn>40&#160;835</m:mn>
              </m:mrow>
            </m:math>
            <p><em>Opción B:</em></p>
            <m:math>
              <m:mrow>
                <m:mn>5</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>7</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>9</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>1</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>0</m:mn></m:msup>
                <m:mo>=</m:mo><m:mn>50&#160;000</m:mn><m:mo>+</m:mo><m:mn>700</m:mn><m:mo>+</m:mo><m:mn>90</m:mn><m:mo>+</m:mo><m:mn>1</m:mn>
                <m:mo>=</m:mo><m:mn>50&#160;791</m:mn>
              </m:mrow>
            </m:math>
            <p><em>Opción C:</em></p>
            <m:math>
              <m:mrow>
                <m:mn>6</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>4</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>1</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>3</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>2</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>4</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup>
                <m:mo>=</m:mo><m:mn>60&#160;000</m:mn><m:mo>+</m:mo><m:mn>1000</m:mn><m:mo>+</m:mo><m:mn>200</m:mn><m:mo>+</m:mo><m:mn>40</m:mn>
                <m:mo>=</m:mo><m:mn>61&#160;240</m:mn>
              </m:mrow>
            </m:math>
            <p><em>Opción D:</em></p>
            <m:math>
              <m:mrow>
                <m:mn>1</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>5</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>2</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>3</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>3</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>2</m:mn></m:msup>
                <m:mo>+</m:mo><m:mn>4</m:mn><m:mo>⋅</m:mo><m:msup><m:mn>10</m:mn><m:mn>1</m:mn></m:msup>
                <m:mo>=</m:mo><m:mn>100&#160;000</m:mn><m:mo>+</m:mo><m:mn>2000</m:mn><m:mo>+</m:mo><m:mn>300</m:mn><m:mo>+</m:mo><m:mn>40</m:mn>
                <m:mo>=</m:mo><m:mn>102&#160;340</m:mn>
              </m:mrow>
            </m:math>
          </li>
          <li>
            <p><strong>Paso 3: Comparar cada resultado con el intervalo pedido</strong></p>
            <p>Opción A: <m:math><m:mrow><m:mn>40&#160;835</m:mn><m:mo>&lt;</m:mo><m:mn>50&#160;000</m:mn></m:mrow></m:math>. No sirve.</p>
            <p>Opción B: <m:math><m:mrow><m:mn>50&#160;000</m:mn><m:mo>&lt;</m:mo><m:mn>50&#160;791</m:mn><m:mo>&lt;</m:mo><m:mn>60&#160;000</m:mn></m:mrow></m:math>. Sí sirve.</p>
            <p>Opción C: <m:math><m:mrow><m:mn>61&#160;240</m:mn><m:mo>&gt;</m:mo><m:mn>60&#160;000</m:mn></m:mrow></m:math>. No sirve.</p>
            <p>Opción D: <m:math><m:mrow><m:mn>102&#160;340</m:mn><m:mo>&gt;</m:mo><m:mn>60&#160;000</m:mn></m:mrow></m:math>. No sirve.</p>
          </li>
          <li>
            <p><strong>Conclusión</strong></p>
            <p>La única expresión que representa un número mayor que 50 000 y menor que 60 000 es la <strong>opción B</strong>, porque su valor es <m:math><m:mrow><m:mn>50&#160;791</m:mn></m:mrow></m:math>.</p>
          </li>
        </ol>
      </qti-content-body>
    </qti-feedback-block>
  </qti-item-body>
  <qti-response-processing>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceB</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-base-value base-type="float">1</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceB</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceA</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceA</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceC</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceC</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceD</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceD</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_NoResponse</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else>
    </qti-response-condition>
  </qti-response-processing>
</qti-assessment-item>