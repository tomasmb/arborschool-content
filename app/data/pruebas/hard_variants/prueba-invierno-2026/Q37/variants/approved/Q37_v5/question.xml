<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0" xmlns:m="http://www.w3.org/1998/Math/MathML" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" identifier="Q37_v5" title="Q37_v5" time-dependent="false" adaptive="false" xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd">
  <qti-response-declaration identifier="RESPONSE" cardinality="single" base-type="identifier">
    <qti-correct-response>
      <qti-value>ChoiceB</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="FEEDBACK" cardinality="single" base-type="identifier"/>
  <qti-outcome-declaration identifier="SOLUTION" cardinality="single" base-type="identifier"/>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float"><qti-default-value><qti-value>0</qti-value></qti-default-value></qti-outcome-declaration><qti-item-body>
    <p>
      Considera la función k definida por 
      <m:math>
        <m:mi>k</m:mi>
        <m:mo>(</m:mo>
        <m:mi>x</m:mi>
        <m:mo>)</m:mo>
        <m:mo>=</m:mo>
        <m:mn>8</m:mn>
        <m:mi>x</m:mi>
        <m:mo>+</m:mo>
        <m:mi>b</m:mi>
      </m:math>, con dominio el conjunto de los números reales.
      Se sabe que, para 
      <m:math>
        <m:mi>x</m:mi>
        <m:mo>=</m:mo>
        <m:mn>5</m:mn>
      </m:math>, se obtiene
      <m:math>
        <m:mi>k</m:mi>
        <m:mo>(</m:mo>
        <m:mn>5</m:mn>
        <m:mo>)</m:mo>
        <m:mo>=</m:mo>
        <m:mn>35</m:mn>
      </m:math>.
      
      
      
      
      ¿Cuál es el valor de 
      <m:math>
        <m:mi>b</m:mi>
      </m:math>?
    </p>
    <qti-choice-interaction response-identifier="RESPONSE" shuffle="false" max-choices="1">
      <qti-prompt>Selecciona la alternativa correcta.</qti-prompt>
      
      <qti-simple-choice identifier="ChoiceA">
        <m:math>
          <m:mn>5</m:mn>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceA" outcome-identifier="FEEDBACK">Incorrecto. Si <m:math><m:mi>b</m:mi><m:mo>=</m:mo><m:mn>5</m:mn></m:math>, entonces <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mn>5</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>8</m:mn><m:mo>×</m:mo><m:mn>5</m:mn><m:mo>+</m:mo><m:mn>5</m:mn><m:mo>=</m:mo><m:mn>40</m:mn><m:mo>+</m:mo><m:mn>5</m:mn><m:mo>=</m:mo><m:mn>45</m:mn></m:math>. Pero el enunciado indica que <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mn>5</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>35</m:mn></m:math>, y <m:math><m:mn>45</m:mn><m:mo>≠</m:mo><m:mn>35</m:mn></m:math>.</qti-feedback-inline>
      </qti-simple-choice>
      <qti-simple-choice identifier="ChoiceB">
        <m:math>
          <m:mo>−</m:mo>
          <m:mn>5</m:mn>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceB" outcome-identifier="FEEDBACK">¡Correcto! Al reemplazar <m:math><m:mi>x</m:mi><m:mo>=</m:mo><m:mn>5</m:mn></m:math> en <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>8</m:mn><m:mi>x</m:mi><m:mo>+</m:mo><m:mi>b</m:mi></m:math>, se obtiene <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mn>5</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>8</m:mn><m:mo>×</m:mo><m:mn>5</m:mn><m:mo>+</m:mo><m:mi>b</m:mi><m:mo>=</m:mo><m:mn>40</m:mn><m:mo>+</m:mo><m:mi>b</m:mi></m:math>. Como <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mn>5</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>35</m:mn></m:math>, resulta <m:math><m:mn>40</m:mn><m:mo>+</m:mo><m:mi>b</m:mi><m:mo>=</m:mo><m:mn>35</m:mn></m:math>, por lo tanto <m:math><m:mi>b</m:mi><m:mo>=</m:mo><m:mn>35</m:mn><m:mo>−</m:mo><m:mn>40</m:mn><m:mo>=</m:mo><m:mo>−</m:mo><m:mn>5</m:mn></m:math>.</qti-feedback-inline>
      </qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceC">
        <m:math>
          <m:mfrac>
            <m:mn>7</m:mn>
            <m:mn>8</m:mn>
          </m:mfrac>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceC" outcome-identifier="FEEDBACK">Incorrecto. Si <m:math><m:mi>b</m:mi><m:mo>=</m:mo><m:mfrac><m:mn>7</m:mn><m:mn>8</m:mn></m:mfrac></m:math>, entonces <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mn>5</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>8</m:mn><m:mo>×</m:mo><m:mn>5</m:mn><m:mo>+</m:mo><m:mfrac><m:mn>7</m:mn><m:mn>8</m:mn></m:mfrac><m:mo>=</m:mo><m:mn>40</m:mn><m:mo>+</m:mo><m:mfrac><m:mn>7</m:mn><m:mn>8</m:mn></m:mfrac></m:math>. Como <m:math><m:mn>40</m:mn><m:mo>=</m:mo><m:mfrac><m:mn>320</m:mn><m:mn>8</m:mn></m:mfrac></m:math>, se obtiene <m:math><m:mfrac><m:mn>320</m:mn><m:mn>8</m:mn></m:mfrac><m:mo>+</m:mo><m:mfrac><m:mn>7</m:mn><m:mn>8</m:mn></m:mfrac><m:mo>=</m:mo><m:mfrac><m:mn>327</m:mn><m:mn>8</m:mn></m:mfrac></m:math>, que es distinto de <m:math><m:mn>35</m:mn></m:math>.</qti-feedback-inline>
      </qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceD">
        <m:math>
          <m:mfrac>
            <m:mn>8</m:mn>
            <m:mn>7</m:mn>
          </m:mfrac>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceD" outcome-identifier="FEEDBACK">Incorrecto. Si <m:math><m:mi>b</m:mi><m:mo>=</m:mo><m:mfrac><m:mn>8</m:mn><m:mn>7</m:mn></m:mfrac></m:math>, entonces <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mn>5</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>8</m:mn><m:mo>×</m:mo><m:mn>5</m:mn><m:mo>+</m:mo><m:mfrac><m:mn>8</m:mn><m:mn>7</m:mn></m:mfrac><m:mo>=</m:mo><m:mn>40</m:mn><m:mo>+</m:mo><m:mfrac><m:mn>8</m:mn><m:mn>7</m:mn></m:mfrac></m:math>. Como <m:math><m:mn>40</m:mn><m:mo>=</m:mo><m:mfrac><m:mn>280</m:mn><m:mn>7</m:mn></m:mfrac></m:math>, resulta <m:math><m:mfrac><m:mn>280</m:mn><m:mn>7</m:mn></m:mfrac><m:mo>+</m:mo><m:mfrac><m:mn>8</m:mn><m:mn>7</m:mn></m:mfrac><m:mo>=</m:mo><m:mfrac><m:mn>288</m:mn><m:mn>7</m:mn></m:mfrac></m:math>, que es distinto de <m:math><m:mn>35</m:mn></m:math>.</qti-feedback-inline>
      </qti-simple-choice>
    </qti-choice-interaction>
    <qti-feedback-block identifier="show" outcome-identifier="SOLUTION" show-hide="show">
      <qti-content-body>
        <p><strong>Resolución paso a paso</strong></p>
        <ol>
          <li>
            <p><strong>Paso 1: Reemplazar el valor conocido en la función</strong></p>
            <p>La función es <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>8</m:mn><m:mi>x</m:mi><m:mo>+</m:mo><m:mi>b</m:mi></m:math>.</p>
            <p>Como <m:math><m:mi>x</m:mi><m:mo>=</m:mo><m:mn>5</m:mn></m:math>, se obtiene <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mn>5</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>8</m:mn><m:mo>×</m:mo><m:mn>5</m:mn><m:mo>+</m:mo><m:mi>b</m:mi></m:math>.</p>
          </li>
          <li>
            <p><strong>Paso 2: Usar el dato entregado por el enunciado</strong></p>
            <p>El enunciado dice que <m:math><m:mi>k</m:mi><m:mo>(</m:mo><m:mn>5</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:mn>35</m:mn></m:math>.</p>
            <p>Entonces, <m:math><m:mn>8</m:mn><m:mo>×</m:mo><m:mn>5</m:mn><m:mo>+</m:mo><m:mi>b</m:mi><m:mo>=</m:mo><m:mn>35</m:mn></m:math>.</p>
          </li>
          <li>
            <p><strong>Paso 3: Efectuar la multiplicación</strong></p>
            <p><m:math><m:mn>8</m:mn><m:mo>×</m:mo><m:mn>5</m:mn><m:mo>=</m:mo><m:mn>40</m:mn></m:math>.</p>
            <p>Por lo tanto, la ecuación queda <m:math><m:mn>40</m:mn><m:mo>+</m:mo><m:mi>b</m:mi><m:mo>=</m:mo><m:mn>35</m:mn></m:math>.</p>
          </li>
          <li>
            <p><strong>Paso 4: Despejar</strong></p>
            <p>Restamos <m:math><m:mn>40</m:mn></m:math> en ambos lados:</p>
            <p><m:math><m:mi>b</m:mi><m:mo>=</m:mo><m:mn>35</m:mn><m:mo>−</m:mo><m:mn>40</m:mn></m:math>.</p>
            <p><m:math><m:mi>b</m:mi><m:mo>=</m:mo><m:mo>−</m:mo><m:mn>5</m:mn></m:math>.</p>
          </li>
          <li>
            <p><strong>Conclusión</strong></p>
            <p>El valor de <m:math><m:mi>b</m:mi></m:math> es <m:math><m:mo>−</m:mo><m:mn>5</m:mn></m:math>, que corresponde a la alternativa B.</p>
          </li>
        </ol>
      </qti-content-body>
    </qti-feedback-block>
  </qti-item-body>
  <qti-response-processing>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceB</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-base-value base-type="float">1</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceB</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceA</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceA</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceC</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceC</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceD</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceD</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceA</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else>
    </qti-response-condition>
  </qti-response-processing>
</qti-assessment-item>