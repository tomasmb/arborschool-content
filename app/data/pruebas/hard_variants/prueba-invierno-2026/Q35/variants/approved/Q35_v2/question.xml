            <m:mn>26000</m:mn>
            <m:mtext> y </m:mtext>
            <m:mi>E</m:mi>
            <m:mo>=</m:mo>
            <m:mfrac>
              <m:mn>70</m:mn>
              <m:mn>100</m:mn>
            </m:mfrac>
            <m:mi>E</m:mi>
          </m:mrow>
        </m:math>
