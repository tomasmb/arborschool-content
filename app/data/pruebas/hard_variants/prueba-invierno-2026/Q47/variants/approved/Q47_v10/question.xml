        <m:math><m:mn>46800</m:mn><m:msup><m:mi>cm</m:mi><m:mn>2</m:mn></m:msup></m:math>
        de superficie del armario.
      </qti-simple-choice>
      <qti-simple-choice identifier="ChoiceC">
        Se deben pintar
        <m:math><m:mn>41600</m:mn><m:msup><m:mi>cm</m:mi><m:mn>2</m:mn></m:msup></m:math>
        de superficie del armario.
      </qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceD">
