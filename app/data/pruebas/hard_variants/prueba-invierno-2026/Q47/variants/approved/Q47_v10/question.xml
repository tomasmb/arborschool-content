        <m:math><m:mn>4160</m:mn><m:msup><m:mi>cm</m:mi><m:mn>2</m:mn></m:msup></m:math>
        de superficie del armario.
      </qti-simple-choice>
    </qti-choice-interaction>
  </qti-item-body>
