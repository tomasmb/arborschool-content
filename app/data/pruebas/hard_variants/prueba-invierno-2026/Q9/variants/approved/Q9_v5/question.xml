            <m:mn>90</m:mn>
            <m:mo>+</m:mo>
            <m:mn>50</m:mn>
            <m:mo>)</m:mo>
          </m:mrow>
        </m:math>
        <span> kcal</span>
      </qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceD">
        <m:math>
          <m:mrow>
            <m:mo>(</m:mo>
            <m:mn>2</m:mn>
            <m:mo>+</m:mo>
            <m:mn>3</m:mn>
            <m:mo>)</m:mo>
