<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0" xmlns:m="http://www.w3.org/1998/Math/MathML" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" identifier="Q27_v9" title="Q27_v9" time-dependent="false" adaptive="false" xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd">
  <qti-response-declaration identifier="RESPONSE" cardinality="single" base-type="identifier">
    <qti-correct-response>
      <qti-value>ChoiceB</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="FEEDBACK" cardinality="single" base-type="identifier"/>
  <qti-outcome-declaration identifier="SOLUTION" cardinality="single" base-type="identifier"/>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float"><qti-default-value><qti-value>0</qti-value></qti-default-value></qti-outcome-declaration><qti-item-body>
    <qti-choice-interaction response-identifier="RESPONSE" shuffle="false" max-choices="1">
      <qti-prompt>
        ¿Cuál de las siguientes igualdades es verdadera?
        
        <m:math>
          <m:mrow>
            <m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup>
            <m:mo>−</m:mo>
            <m:mn>5</m:mn><m:mi>x</m:mi>
            <m:mo>−</m:mo>
            <m:mn>24</m:mn>
          </m:mrow>
        </m:math>
      </qti-prompt>
      
      <qti-simple-choice identifier="ChoiceA">
        <m:math>
          <m:mrow>
            <m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup>
            <m:mo>−</m:mo>
            <m:mn>5</m:mn><m:mi>x</m:mi>
            <m:mo>−</m:mo>
            <m:mn>24</m:mn>
            <m:mo>=</m:mo>
            <m:mfenced>
              <m:mrow>
                <m:mi>x</m:mi>
                <m:mo>−</m:mo>
                <m:mn>6</m:mn>
              </m:mrow>
            </m:mfenced>
            <m:mfenced>
              <m:mrow>
                <m:mi>x</m:mi>
                <m:mo>+</m:mo>
                <m:mn>4</m:mn>
              </m:mrow>
            </m:mfenced>
          </m:mrow>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceA" outcome-identifier="FEEDBACK">Incorrecto. Al desarrollar <m:math><m:mrow><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>6</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>4</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>4</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>6</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>2</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>, que no es igual a <m:math><m:mrow><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>.</qti-feedback-inline>
      </qti-simple-choice>
      <qti-simple-choice identifier="ChoiceB">
        <m:math>
          <m:mrow>
            <m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup>
            <m:mo>−</m:mo>
            <m:mn>5</m:mn><m:mi>x</m:mi>
            <m:mo>−</m:mo>
            <m:mn>24</m:mn>
            <m:mo>=</m:mo>
            <m:mfenced>
              <m:mrow>
                <m:mi>x</m:mi>
                <m:mo>−</m:mo>
                <m:mn>8</m:mn>
              </m:mrow>
            </m:mfenced>
            <m:mfenced>
              <m:mrow>
                <m:mi>x</m:mi>
                <m:mo>+</m:mo>
                <m:mn>3</m:mn>
              </m:mrow>
            </m:mfenced>
          </m:mrow>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceB" outcome-identifier="FEEDBACK">¡Correcto! Al desarrollar <m:math><m:mrow><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>8</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>3</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>3</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>8</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>. Por lo tanto, esa igualdad sí es verdadera.</qti-feedback-inline>
      </qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceC">
        <m:math>
          <m:mrow>
            <m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup>
            <m:mo>−</m:mo>
            <m:mn>5</m:mn><m:mi>x</m:mi>
            <m:mo>−</m:mo>
            <m:mn>24</m:mn>
            <m:mo>=</m:mo>
            <m:mfenced>
              <m:mrow>
                <m:mi>x</m:mi>
                <m:mo>−</m:mo>
                <m:mn>2</m:mn>
              </m:mrow>
            </m:mfenced>
            <m:mfenced>
              <m:mrow>
                <m:mi>x</m:mi>
                <m:mo>−</m:mo>
                <m:mn>3</m:mn>
              </m:mrow>
            </m:mfenced>
          </m:mrow>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceC" outcome-identifier="FEEDBACK">Incorrecto. Al desarrollar <m:math><m:mrow><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>2</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>3</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>3</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>2</m:mn><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>6</m:mn><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>6</m:mn></m:mrow></m:math>, que no coincide con <m:math><m:mrow><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>.</qti-feedback-inline>
      </qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceD">
        <m:math>
          <m:mrow>
            <m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup>
            <m:mo>−</m:mo>
            <m:mn>5</m:mn><m:mi>x</m:mi>
            <m:mo>−</m:mo>
            <m:mn>24</m:mn>
            <m:mo>=</m:mo>
            <m:mfenced>
              <m:mrow>
                <m:mi>x</m:mi>
                <m:mo>+</m:mo>
                <m:mn>8</m:mn>
              </m:mrow>
            </m:mfenced>
            <m:mfenced>
              <m:mrow>
                <m:mi>x</m:mi>
                <m:mo>−</m:mo>
                <m:mn>3</m:mn>
              </m:mrow>
            </m:mfenced>
          </m:mrow>
        </m:math>
        <qti-feedback-inline identifier="FB_ChoiceD" outcome-identifier="FEEDBACK">Incorrecto. Al desarrollar <m:math><m:mrow><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>8</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>3</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>3</m:mn><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>8</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>, y eso no es igual a <m:math><m:mrow><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>.</qti-feedback-inline>
      </qti-simple-choice>
    </qti-choice-interaction>
    <qti-feedback-block identifier="show" outcome-identifier="SOLUTION" show-hide="show">
      <qti-content-body>
        <p><strong>Resolución paso a paso por desarrollo de productos</strong></p>
        <ol>
          <li>
            <p><strong>Paso 1: Revisar qué debe ocurrir</strong></p>
            <p>La igualdad verdadera debe producir exactamente el polinomio <m:math><m:mrow><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math> al multiplicar los dos factores.</p>
          </li>
          <li>
            <p><strong>Paso 2: Desarrollar cada alternativa</strong></p>
            <p><em>Opción A:</em> <m:math><m:mrow><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>6</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>4</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>4</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>6</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>2</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>.</p>
            <p><em>Opción B:</em> <m:math><m:mrow><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>8</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>3</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>3</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>8</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>.</p>
            <p><em>Opción C:</em> <m:math><m:mrow><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>2</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>3</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>3</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>2</m:mn><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>6</m:mn><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>6</m:mn></m:mrow></m:math>.</p>
            <p><em>Opción D:</em> <m:math><m:mrow><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>8</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>3</m:mn><m:mo>)</m:mo><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>3</m:mn><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>8</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn><m:mo>=</m:mo><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>+</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>.</p>
          </li>
          <li>
            <p><strong>Paso 3: Comparar con el polinomio dado</strong></p>
            <p>El polinomio buscado es <m:math><m:mrow><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn></m:mrow></m:math>. Solo la opción B produce exactamente ese resultado.</p>
          </li>
          <li>
            <p><strong>Conclusión</strong></p>
            <p>La igualdad verdadera es <m:math><m:mrow><m:msup><m:mi>x</m:mi><m:mn>2</m:mn></m:msup><m:mo>−</m:mo><m:mn>5</m:mn><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>24</m:mn><m:mo>=</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>−</m:mo><m:mn>8</m:mn><m:mo>)</m:mo><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>3</m:mn><m:mo>)</m:mo></m:mrow></m:math>, que corresponde a la alternativa B.</p>
          </li>
        </ol>
      </qti-content-body>
    </qti-feedback-block>
  </qti-item-body>
  <qti-response-processing>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceB</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-base-value base-type="float">1</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceB</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceA</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceA</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceC</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceC</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-base-value base-type="identifier">ChoiceD</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceD</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">FB_ChoiceA</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="SOLUTION">
          <qti-base-value base-type="identifier">show</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else>
    </qti-response-condition>
  </qti-response-processing>
</qti-assessment-item>