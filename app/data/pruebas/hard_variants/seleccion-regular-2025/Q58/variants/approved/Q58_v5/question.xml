  <qti-item-body>
    <p>En el patio de un colegio se dibujan cuatro zonas de juego circulares con perímetros de <m:math><m:mn>16</m:mn><m:mi>
π</m:mi><m:mi>m</m:mi></m:math>, <m:math><m:mn>12</m:mn><m:mi>π</m:mi><m:mi>m</m:mi></m:math>, <m:math><m:mn>8</m:mn><m:mi>π</m:mi><m:mi>m</m:mi></m:math> y <m:math><m:mn>4</m:mn><m:mi>π</m:mi><m:mi>m</m:mi></m:math>, que se desean pintar para una actividad escolar.</p>
    <p>Para estimar la cantidad de pintura, la profesora propone distintas expresiones para calcular el área total de estas cuatro zonas. ¿Cuál de las siguientes expresiones representa correctamente ese cálculo?</p>
    <qti-choice-interaction response-identifier="RESPONSE" max-choices="1" shuffle="true">
      
      <qti-simple-choice identifier="ChoiceA">
        <m:math>
          <m:mi>π</m:mi>
          <m:mo>(</m:mo>
          <m:msup>
            <m:mrow><m:mn>16</m:mn><m:mi>π</m:mi></m:mrow>
            <m:mn>2</m:mn>
          </m:msup>
          <m:mo>+</m:mo>
          <m:msup>
            <m:mrow><m:mn>12</m:mn><m:mi>π</m:mi></m:mrow>
            <m:mn>2</m:mn>
          </m:msup>
          <m:mo>+</m:mo>
          <m:msup>
            <m:mrow><m:mn>8</m:mn><m:mi>π</m:mi></m:mrow>
            <m:mn>2</m:mn>
          </m:msup>
          <m:mo>+</m:mo>
          <m:msup>
            <m:mrow><m:mn>4</m:mn><m:mi>π</m:mi></m:mrow>
            <m:mn>2</m:mn>
          </m:msup>
          <m:mo>)</m:mo>
          <m:mo>.</m:mo>
          <m:msup><m:mi>m</m:mi><m:mn>2</m:mn></m:msup>
        </m:math>
      </qti-simple-choice>
      <qti-simple-choice identifier="ChoiceB">
        <m:math>
          <m:mi>π</m:mi>
          <m:mo>(</m:mo>
          <m:msup><m:mn>8</m:mn><m:mn>2</m:mn></m:msup>
          <m:mo>+</m:mo>
          <m:msup><m:mn>6</m:mn><m:mn>2</m:mn></m:msup>
          <m:mo>+</m:mo>
          <m:msup><m:mn>4</m:mn><m:mn>2</m:mn></m:msup>
          <m:mo>+</m:mo>
          <m:msup><m:mn>2</m:mn><m:mn>2</m:mn></m:msup>
          <m:mo>)</m:mo>
          <m:mo>.</m:mo>
          <m:msup><m:mi>m</m:mi><m:mn>2</m:mn></m:msup>
        </m:math>
      </qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceC">
        <m:math>
          <m:mi>π</m:mi>
          <m:mo>(</m:mo>
          <m:mrow>
            <m:mn>16</m:mn><m:mi>π</m:mi>
            <m:mo>+</m:mo>
            <m:mn>12</m:mn><m:mi>π</m:mi>
            <m:mo>+</m:mo>
            <m:mn>8</m:mn><m:mi>π</m:mi>
            <m:mo>+</m:mo>
            <m:mn>4</m:mn><m:mi>π</m:mi>
          </m:mrow>
          <m:mo>)</m:mo>
          <m:msup><m:mn>2</m:mn><m:mn>2</m:mn></m:msup>
          <m:mo>.</m:mo>
          <m:msup><m:mi>m</m:mi><m:mn>2</m:mn></m:msup>
        </m:math>
      </qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceD">
        <m:math>
          <m:mi>π</m:mi>
          <m:mo>(</m:mo>
          <m:mfrac><m:mn>16</m:mn><m:mn>2</m:mn></m:mfrac>
          <m:mo>+</m:mo>
          <m:mfrac><m:mn>12</m:mn><m:mn>2</m:mn></m:mfrac>
          <m:mo>+</m:mo>
          <m:mfrac><m:mn>8</m:mn><m:mn>2</m:mn></m:mfrac>
          <m:mo>+</m:mo>
          <m:mfrac><m:mn>4</m:mn><m:mn>2</m:mn></m:mfrac>
          <m:mo>)</m:mo>
          <m:mo>.</m:mo>
          <m:msup><m:mi>m</m:mi><m:mn>2</m:mn></m:msup>
        </m:math>
      </qti-simple-choice>
    </qti-choice-interaction>
