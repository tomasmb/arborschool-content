ple-choice><qti-simple-choice identifier="ChoiceD"><m:math><m:mn>4</m:mn><m:mo>(</m:mo><m:mi>x</m:mi><m:mo>+</m:mo><m:mn>450</m:mn><m:mo>)</m:mo><m:mo>+</m:mo><m:mi>x</m:mi><m:mo>=</m:mo><m:mn>22000</m:mn></m:math></qti-simple-choice></qti-choice-interaction></qti-item-body><qti-response-processing template="https://purl.imsglobal.org/spec/qti/v3p0/rptemplates/match_correct.xml" /></qti-assessment-item>