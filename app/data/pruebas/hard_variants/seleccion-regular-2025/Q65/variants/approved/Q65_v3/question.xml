      <qti-simple-choice identifier="ChoiceA">40°</qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceB">45°</qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceC">50°</qti-simple-choice>
      <qti-simple-choice identifier="ChoiceD">100°</qti-simple-choice>
