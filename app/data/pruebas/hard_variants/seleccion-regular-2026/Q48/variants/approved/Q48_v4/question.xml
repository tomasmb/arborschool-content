      <qti-simple-choice identifier="ChoiceB">30</qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceC">34</qti-simple-choice>
      
      <qti-simple-choice identifier="ChoiceD">38</qti-simple-choice>
    </qti-choice-interaction>
  </qti-item-body>
